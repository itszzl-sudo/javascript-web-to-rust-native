{
  "name": "@irisverse/jade",
  "version": "0.1.0",
  "description": "JavaScript to Native compiler - No binary download required",
  "keywords": [
    "compiler",
    "native",
    "cranelift",
    "rust",
    "vue",
    "react",
    "svelte"
  ],
  "author": "IrisVerse",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/irisverse/javascript-web-to-rust-native"
  },
  "bin": {
    "jade": "./bin/jade.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "bin/",
    "src/",
    "dist/",
    "wasm/",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "build:wasm": "cd ../.. && cargo build --release -p cranelift-compiler --target wasm32-unknown-unknown",
    "test": "node bin/jade.js --help"
  },
  "dependencies": {
    "@swc/core": "^1.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
